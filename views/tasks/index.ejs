  <table border="1" cellpadding="8">
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Notes</th>
        <th>Due</th>
        <th>Created by</th>
        <th>Assigned to</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% tasks.forEach((task) => { %>
        <tr>
          <td><%= task.title %></td>
          <td><%= task.status === "open" ? "To Do" : "Done" %></td>
          <td><%= task.notes || "No notes" %></td>
          <td><%= task.dueDate ? new Date(task.dueDate).toLocaleDateString() : "No due date" %></td>
          <td><%= task.createdByName || "Unknown" %></td>
          <td><%= task.assignedToName || "Unassigned" %></td>
          <td>
            <form method="GET" action="/tasks/edit/<%= task._id %>" style="display: inline">
              <button>Edit</button>
            </form>

            <form method="POST" action="/tasks/delete/<%= task._id %>" style="display: inline">
              <input type="hidden" name="_csrf" value="<%= _csrf %>" />
              <button>Delete</button>
            </form>

            <!-- Update Status -->
<form method="POST" action="/tasks/status/<%= task._id %>" style="display: inline">
  <input type="hidden" name="_csrf" value="<%= _csrf %>" />

  <select name="status">
    <option value="open" <%= task.status === "open" ? "selected" : "" %>>To Do</option>
    <option value="done" <%= task.status === "done" ? "selected" : "" %>>Done</option>
  </select>

  <button>Update Status</button>
</form> 
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% } %>

<%- include("../partials/footer.ejs") %>