<%- include("../partials/head.ejs") %>

<%- include("../partials/header.ejs") %>

<!-- App navigation -->
<form method="GET" action="/tasks/new"  style="display: inline">
  <button>Add New Task</button>
</form>

<!-- Refresh button -->
 <form method="GET" action="/tasks" style="display: inline">
  <button>Refresh</button>
</form>


<!-- <p>Family Code: <%= currentFamilyCode %></p> -->

<% if (tasks.length === 0) { %>
  <p>No tasks yet. Click "Add New Task" to create one.</p>
<% } else { %>

